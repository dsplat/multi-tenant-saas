+
+        if (empty($config)) {
+            return ['valid' => false, 'message' => trans('payment.driver_not_configured', ['driver' => $driver, 'tenant' => $tenantId])];
+        }
+
+        $requiredFields = match ($driver) {
+            'wechat' => ['app_id', 'mch_id'],
+            'alipay' => ['app_id', 'private_key', 'ali_public_key'],
+            'paypal' => ['client_id', 'client_secret'],
