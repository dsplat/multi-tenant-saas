+        if (! $oauthAccount || ! $oauthAccount->refresh_token) {
+            return false;
+        }
+
+        try {
+            $refreshToken = decrypt($oauthAccount->refresh_token);
+            if ($oauthAccount->tenant_id === null) {
+                return false;
+            }
+
+            $config = self::getOAuthConfig((int) $oauthAccount->tenant_id, $provider);
+
+            // 调用提供商 refresh 接口（按提供商差异定制，这里使用通用 OAuth2 协议）
