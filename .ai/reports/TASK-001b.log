+            'unionpay' => ['mer_id', 'cert_path'],
+            default => null,
+        };
+
+        if ($requiredFields === null) {
+            return ['valid' => false, 'message' => trans('payment.unsupported_driver').": {$driver}"];
+        }
+
+        foreach ($requiredFields as $field) {
+            if (empty($config[$field])) {
+                return ['valid' => false, 'message' => trans('payment.missing_field', ['field' => $field, 'driver' => $driver])];
+            }
+        }
+
+        return ['valid' => true, 'message' => trans('payment.config_valid')];
+    }
+
+    /**
+     * 测试支付连接（仅校验配置完整性，不发起真实交易）
+     *
+     * @return array{success: bool, message: string}
+     */
+    public static function testConnection(int $tenantId, string $driver): array
+    {
+        $validation = self::validateConfig($tenantId, $driver);
+
+        if (! $validation['valid']) {
+            return ['success' => false, 'message' => $validation['message']];
+        }
+
+        try {
+            if (in_array($driver, ['paypal', 'stripe', 'unionpay'])) {
+                return ['success' => true, 'message' => trans('payment.config_validation_only')];
+            }
+
+            self::createPayInstance($tenantId, $driver);
+
+            return ['success' => true, 'message' => trans('payment.connection_ok')];
+        } catch (\Throwable $e) {
+            Log::error('[PayService] testConnection failed', [
+                'tenant_id' => $tenantId,
+                'driver' => $driver,
+                'error' => $e->getMessage(),
+            ]);
+
+            return ['success' => false, 'message' => trans('payment.connection_failed')];
         }
     }
 }
