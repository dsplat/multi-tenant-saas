+        $drivers = ['wechat', 'alipay', 'paypal', 'stripe', 'unionpay'];
+        $export = [];
+        $sensitive = ['private_key', 'public_key_path', 'secret', 'client_secret', 'secret_key', 'cert_password'];
+
+        foreach ($drivers as $driver) {
+            $config = self::getConfig($tenantId, $driver);
+            foreach ($config as $key => $value) {
+                if (in_array($key, $sensitive) && ! empty($value)) {
+                    $config[$key] = '********';
+                }
+            }
+            $export[$driver] = $config;
+        }
+
+        return $export;
+    }
+
+    /**
+     * 验证支付配置完整性
+     *
+     * @param  int  $tenantId  租户 ID
+     * @param  string  $driver  驱动
+     * @return array{valid: bool, message: string}
+     */
+    public static function validateConfig(int $tenantId, string $driver): array
+    {
+        $config = self::getConfig($tenantId, $driver);
+
+        if (empty($config)) {
+            return ['valid' => false, 'message' => trans('payment.driver_not_configured', ['driver' => $driver, 'tenant' => $tenantId])];
+        }
+
+        $requiredFields = match ($driver) {
+            'wechat' => ['app_id', 'mch_id'],
+            'alipay' => ['app_id', 'private_key', 'ali_public_key'],
+            'paypal' => ['client_id', 'client_secret'],
+            'stripe' => ['secret_key'],
+            'unionpay' => ['mer_id', 'cert_path'],
+            default => [],
+        };
+
+        foreach ($requiredFields as $field) {
+            if (empty($config[$field])) {
+                return ['valid' => false, 'message' => trans('payment.missing_field', ['field' => $field, 'driver' => $driver])];
+            }
+        }
+
+        return ['valid' => true, 'message' => trans('payment.config_valid')];
+    }
+
+    /**
+     * 测试支付连接（仅校验配置完整性，不发起真实交易）
+     *
+     * @return array{success: bool, message: string}
+     */
+    public static function testConnection(int $tenantId, string $driver): array
+    {
+        $validation = self::validateConfig($tenantId, $driver);
+
+        if (! $validation['valid']) {
+            return ['success' => false, 'message' => $validation['message']];
+        }
+
+        try {
+            if (in_array($driver, ['paypal', 'stripe', 'unionpay'])) {
+                return ['success' => true, 'message' => trans('payment.connection_ok')];
+            }
+
+            self::createPayInstance($tenantId, $driver);
+
+            return ['success' => true, 'message' => trans('payment.connection_ok')];
+        } catch (\Throwable $e) {
+            return ['success' => false, 'message' => $e->getMessage()];
         }
     }
 }
