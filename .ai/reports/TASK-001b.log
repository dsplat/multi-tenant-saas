+    public static function refreshToken(int $userId, string $provider): bool
+    {
+        if (! config('socialite.security.refresh_enabled', true)) {
+            return false;
+        }
+
+        $oauthAccount = OauthAccount::where('user_id', $userId)
+            ->where('provider', $provider)
+            ->first();
