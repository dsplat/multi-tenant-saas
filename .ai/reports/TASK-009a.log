<?php
namespace MultiTenantSaas\Tests;
use Illuminate\Support\Facades\Event;
use MultiTenantSaas\Models\SubscriptionPlan;
use MultiTenantSaas\Models\Tenant;
use MultiTenantSaas\Models\TenantSetting;
use MultiTenantSaas\Models\TenantUser;
use MultiTenantSaas\Models\User;
use MultiTenantSaas\Services\TenantOnboardingService;
class ServiceDirectTest extends TestCase {
    private TenantOnboardingService $svc;
    protected function setUp(): void {
        parent::setUp();
        $this->svc = new TenantOnboardingService();
        SubscriptionPlan::unguarded(function () {
            SubscriptionPlan::create(['subscription_plan_id' => 1, 'name' => 'free', 'display_name' => 'Free', 'price_monthly' => 0, 'price_yearly' => 0, 'trial_days' => 0, 'is_active' => true, 'sort_order' => 0]);
            SubscriptionPlan::create(['subscription_plan_id' => 2, 'name' => 'basic', 'display_name' => 'Basic', 'price_monthly' => 99, 'price_yearly' => 999, 'trial_days' => 14, 'is_active' => true, 'sort_order' => 1]);
        });
    }
    public function test_full_flow_direct_with_trial(): void {
        Event::fake([TenantCreated::class]);
        $token = $this->svc->startRegistration(['name' => 'Acme Corp', 'admin_email' => 'a@b.test', 'password' => 'Password123']);
        $this->assertSame(2, $this->svc->getStatus($token)['current_step']);
        $this->svc->saveStep($token, 2, ['subdomain' => 'acme']);
        $this->svc->saveStep($token, 3, ['plan' => 'basic', 'trial' => true]);
        $this->svc->saveStep($token, 4, ['skip' => true]);
        $tenant = $this->svc->complete($token);
        $this->assertSame('acme', $tenant->slug);
        $this->assertSame('basic', $tenant->subscription_plan);
        $this->assertNotNull($tenant->trial_ends_at);
        $this->assertTrue($tenant->trial_ends_at->isFuture());
        $this->assertNotNull(User::where('email', 'a@b.test')->first());
        $this->assertTrue(TenantUser::where('tenant_id', $tenant->tenant_id)->exists());
        $this->assertTrue(TenantSetting::withoutGlobalScope(\MultiTenantSaas\Scopes\TenantScope::class)->where('tenant_id', $tenant->tenant_id)->exists());
        $this->assertGreaterThanOrEqual(2, \MultiTenantSaas\Models\Role::where('tenant_id', $tenant->tenant_id)->count());
        Event::assertDispatched(\MultiTenantSaas\Events\TenantCreated::class);
    }
    public function test_cannot_skip(): void {
        $token = $this->svc->startRegistration(['name' => 'X', 'admin_email' => 'x@y.test', 'password' => 'Password123']);
        $this->expectException(\InvalidArgumentException::class);
        $this->svc->saveStep($token, 4, ['skip' => true]);
    }
    public function test_cannot_complete_incomplete(): void {
        $token = $this->svc->startRegistration(['name' => 'X', 'admin_email' => 'x@y.test', 'password' => 'Password123']);
        $this->svc->saveStep($token, 2, ['subdomain' => 'x']);
        $this->expectException(\InvalidArgumentException::class);
        $this->svc->complete($token);
    }
    public function test_duplicate_email(): void {
        $this->svc->startRegistration(['name' => 'A', 'admin_email' => 'dup@y.test', 'password' => 'Password123']);
        $this->expectException(\InvalidArgumentException::class);
        $this->svc->startRegistration(['name' => 'B', 'admin_email' => 'dup@y.test', 'password' => 'Password123']);
    }
    public function test_expired_token(): void {
        $this->assertNull($this->svc->getStatus('bad-token'));
    }
    public function test_resume(): void {
        $token = $this->svc->startRegistration(['name' => 'R', 'admin_email' => 'r@y.test', 'password' => 'Password123']);
        $st = $this->svc->getStatus($token);
        $this->assertSame(2, $st['current_step']);
        $this->assertSame([1], $st['completed_steps']);
        $this->assertArrayNotHasKey('password', $st['data'][1]);
    }
}
EOF
