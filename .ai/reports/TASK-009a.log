<?php

namespace MultiTenantSaas\Tests;

use Illuminate\Support\Facades\Cache;
use Illuminate\Support\Facades\Event;
use MultiTenantSaas\Models\SubscriptionPlan;
use MultiTenantSaas\Models\Tenant;
use MultiTenantSaas\Models\TenantSetting;
use MultiTenantSaas\Models\TenantUser;
use MultiTenantSaas\Models\User;
use MultiTenantSaas\Services\TenantOnboardingService;

class OnboardingSmokeTest extends TestCase
{
    private TenantOnboardingService $service;

    protected function setUp(): void
    {
        parent::setUp();
        $this->service = new TenantOnboardingService();

        SubscriptionPlan::unguarded(function () {
            SubscriptionPlan::create([
                'subscription_plan_id' => 2,
                'name' => 'basic',
                'display_name' => 'Basic Plan',
                'price_monthly' => 99,
                'price_yearly' => 999,
                'trial_days' => 14,
                'is_active' => true,
                'sort_order' => 1,
            ]);
        });
    }

    public function test_full_onboarding_flow_with_trial(): void
    {
        Event::fake();

        // Step 1
        $token = $this->service->startRegistration([
            'name' => 'Acme Corp',
            'admin_email' => 'admin@acme.com',
            'password' => 'secret123',
        ]);
        $this->assertNotEmpty($token);

        $status = $this->service->getStatus($token);
        $this->assertSame(2, $status['current_step']);
        $this->assertSame([1], $status['completed_steps']);
        $this->assertArrayNotHasKey('password', $status['data'][1]);

        // Step 2
        $progress = $this->service->saveStep($token, 2, [
            'domain_type' => 'subdomain',
            'subdomain' => 'acme',
        ]);
        $this->assertSame(3, $progress['current_step']);

        // Step 3
        $progress = $this->service->saveStep($token, 3, [
            'plan_id' => 2,
            'billing_cycle' => 'monthly',
            'start_trial' => true,
        ]);
        $this->assertSame(4, $progress['current_step']);

        // Step 4 (skip payment for trial)
        $progress = $this->service->saveStep($token, 4, ['skip' => true]);
        $this->assertSame(5, $progress['current_step']);

        // Complete
        $tenant = $this->service->complete($token);
        $this->assertInstanceOf(Tenant::class, $tenant);
        $this->assertSame('Acme Corp', $tenant->name);
        $this->assertSame('acme', $tenant->slug);
        $this->assertSame('basic', $tenant->subscription_plan);
        $this->assertNotNull($tenant->trial_ends_at);

        // TenantSetting defaults
        $this->assertSame('Acme Corp', TenantSetting::get($tenant->tenant_id, 'info', 'name'));
        $this->assertTrue(TenantSetting::get($tenant->tenant_id, 'auth', 'allow_password_login'));

        // Admin user + membership
        $user = User::where('email', 'admin@acme.com')->first();
        $this->assertNotNull($user);
        $membership = TenantUser::where('tenant_id', $tenant->tenant_id)->where('user_id', $user->user_id)->first();
        $this->assertNotNull($membership);
        $this->assertSame('tenant_admin', $membership->role);

        // Event fired
        Event::assertDispatched(\MultiTenantSaas\Events\TenantCreated::class);
    }

    public function test_cannot_skip_steps(): void
    {
        $token = $this->service->startRegistration([
            'name' => 'Skip Inc',
            'admin_email' => 'skip@test.com',
            'password' => 'secret123',
        ]);

        $this->expectException(\RuntimeException::class);
        $this->service->saveStep($token, 4, ['skip' => true]);
    }

    public function test_cannot_complete_without_all_steps(): void
    {
        $token = $this->service->startRegistration([
            'name' => 'Early Inc',
            'admin_email' => 'early@test.com',
            'password' => 'secret123',
        ]);
        $this->service->saveStep($token, 2, ['domain_type' => 'subdomain', 'subdomain' => 'early']);

        $this->expectException(\RuntimeException::class);
        $this->service->complete($token);
    }

    public function test_duplicate_email_rejected(): void
    {
        $this->service->startRegistration([
            'name' => 'Dup One',
            'admin_email' => 'dup@test.com',
            'password' => 'secret123',
        ]);

        $this->expectException(\RuntimeException::class);
        $this->service->startRegistration([
            'name' => 'Dup Two',
            'admin_email' => 'dup@test.com',
            'password' => 'secret123',
        ]);
    }

    public function test_expired_token_rejected(): void
    {
        $this->assertNull($this->service->getStatus('nonexistent-token'));
    }
}
EOF
