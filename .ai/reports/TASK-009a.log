<?php
namespace MultiTenantSaas\Tests;
use Illuminate\Support\Facades\Event;
use MultiTenantSaas\Events\TenantCreated;
use MultiTenantSaas\Models\SubscriptionPlan;
use MultiTenantSaas\Models\Tenant;
use MultiTenantSaas\Services\TenantOnboardingService;
class FinalVerify extends TestCase {
    public function test_non_trial_flow(): void {
        Event::fake([TenantCreated::class]);
        SubscriptionPlan::unguarded(function () {
            SubscriptionPlan::create(['subscription_plan_id' => 1, 'name' => 'free', 'display_name' => 'Free', 'price_monthly' => 0, 'price_yearly' => 0, 'trial_days' => 0, 'is_active' => true, 'sort_order' => 0]);
        });
        $svc = new TenantOnboardingService();
        $token = $svc->startRegistration(['name' => 'Acme', 'admin_email' => 'a@b.test', 'password' => 'Password123']);
        $this->assertSame(2, $svc->getStatus($token)['current_step']);
        $svc->saveStep($token, 2, ['subdomain' => 'acme']);
        $svc->saveStep($token, 3, ['plan' => 'free', 'trial' => false]);
        $svc->saveStep($token, 4, ['skip' => true]);
        $tenant = $svc->complete($token);
        $this->assertSame('acme', $tenant->slug);
        $this->assertSame('free', $tenant->subscription_plan);
        $this->assertNotNull(Tenant::where('slug', 'acme')->first());
        Event::assertDispatched(TenantCreated::class);
    }
    public function test_flow_controls(): void {
        SubscriptionPlan::unguarded(function () {
            SubscriptionPlan::create(['subscription_plan_id' => 1, 'name' => 'free', 'display_name' => 'Free', 'price_monthly' => 0, 'price_yearly' => 0, 'trial_days' => 0, 'is_active' => true, 'sort_order' => 0]);
        });
        $svc = new TenantOnboardingService();
        $t = $svc->startRegistration(['name' => 'X', 'admin_email' => 'x@y.test', 'password' => 'Password123']);
        try { $svc->saveStep($t, 4, ['skip' => 1]); $this->fail('should throw'); } catch (\InvalidArgumentException $e) {}
        try { $svc->complete($t); $this->fail('should throw'); } catch (\InvalidArgumentException $e) {}
        try { $svc->startRegistration(['name' => 'Y', 'admin_email' => 'x@y.test', 'password' => 'Password123']); $this->fail('should throw'); } catch (\InvalidArgumentException $e) {}
        $this->assertNull($svc->getStatus('nope'));
        $this->assertTrue(true);
    }
}
EOF
