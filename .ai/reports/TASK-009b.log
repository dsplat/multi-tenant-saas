+    public function register(Request $request)
+    {
+        $validated = $request->validate([
+            'name' => 'required|string|max:255',
+            'admin_email' => 'required|email',
+            'password' => 'required|min:8',
+        ]);
+
+        try {
+            $token = app(TenantOnboardingService::class)->startRegistration($validated);
+
+            return response()->json([
+                'success' => true,
+                'message' => trans('tenant.onboarding.step_completed'),
+                'data' => [
+                    'token' => $token,
+                    'current_step' => 1,
+                ],
+            ], 201);
+        } catch (\Throwable $e) {
+            return response()->json([
+                'success' => false,
+                'message' => trans('tenant.onboarding.registration_failed'),
+            ], 422);
+        }
+    }
+
+    /**
+     * 查询 onboarding 注册进度
+     *
+     * 无需认证，仅限流；通过 ?token=xxx 查询当前进度。
+     */
+    public function onboardingStatus(Request $request)
+    {
+        $token = $request->query('token');
+
+        if (!$token) {
+            return response()->json([
+                'success' => false,
+                'message' => trans('tenant.onboarding.token_required'),
+            ], 422);
+        }
+
+        $status = app(TenantOnboardingService::class)->getStatus($token);
+
+        if (!$status) {
+            return response()->json([
+                'success' => false,
+                'message' => trans('tenant.onboarding.expired'),
+            ], 404);
+        }
+
+        return response()->json([
+            'success' => true,
+            'data' => $status,
+        ]);
+    }
+
+    /**
+     * 提交指定 onboarding 步骤数据
+     *
+     * 无需认证，仅限流；body 中携带 token 字段，其余字段作为该步骤数据。
+     */
+    public function onboardingStep(Request $request, int $step)
+    {
+        $request->validate([
+            'token' => 'required|string',
+        ]);
+
+        $token = $request->input('token');
+        $data = $request->except('token');
+
+        try {
+            $progress = app(TenantOnboardingService::class)->saveStep($token, $step, $data);
+
+            return response()->json([
+                'success' => true,
+                'message' => trans('tenant.onboarding.step_completed'),
+                'data' => $progress,
+            ]);
+        } catch (\InvalidArgumentException $e) {
+            return response()->json([
+                'success' => false,
+                'message' => $e->getMessage(),
+            ], 422);
+        } catch (\Throwable $e) {
+            return response()->json([
+                'success' => false,
+                'message' => trans('tenant.onboarding.step_failed'),
+            ], 500);
+        }
+    }
+
+    /**
+     * 完成 onboarding 注册，触发自动初始化
+     *
+     * 无需认证，仅限流；body 中携带 token 字段。
