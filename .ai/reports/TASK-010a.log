require __DIR__."/vendor/autoload.php";
$contract = MultiTenantSaas\Contracts\AiProviderContract::class;
$providers = [
    MultiTenantSaas\Services\Ai\OpenAiProvider::class,
    MultiTenantSaas\Services\Ai\ZhipuProvider::class,
];
$ifaceMethods = array_map(fn($m) => $m->getName(), (new ReflectionClass($contract))->getMethods());
foreach ($providers as $p) {
    $rc = new ReflectionClass($p);
    $missing = [];
    foreach ($ifaceMethods as $name) {
        if (! $rc->hasMethod($name)) { $missing[] = $name; continue; }
        $im = (new ReflectionClass($contract))->getMethod($name);
        $cm = $rc->getMethod($name);
        // signature compatibility check
        if (! $cm->getParameters() && $im->getParameters()) {} // no-op
    }
    $impls = in_array($contract, class_implements($p) ?: [], true);
    echo $p." implements=".($impls?"YES":"NO")." missing_methods=".(empty($missing)?"none":implode(",",$missing)).PHP_EOL;
}
echo "Contract methods: ".implode(", ", $ifaceMethods).PHP_EOL;
'
