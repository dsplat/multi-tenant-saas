APP_NAME="Multi-Tenant SaaS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=zh_CN

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=saas
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# 支付配置（yansongda/pay）
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_NOTIFY_URL=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_PUBLIC_KEY_PATH=
ALIPAY_APP_ID=
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=
ALIPAY_PUBLIC_KEY=
ALIPAY_PRIVATE_KEY=
ALIPAY_MODE=normal

# 第三方登录（laravel/socialite）
WECHAT_CLIENT_ID=
WECHAT_CLIENT_SECRET=
WECHAT_REDIRECT_URI=/auth/wechat/callback
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_REDIRECT_URI=/auth/dingtalk/callback
FEISHU_CLIENT_ID=
FEISHU_CLIENT_SECRET=
FEISHU_REDIRECT_URI=/auth/feishu/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=/auth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=/auth/google/callback

# 健康检查
HEALTH_SLACK_WEBHOOK_URL=
HEALTH_MAIL_TO=

# Sentry 错误追踪
SENTRY_LARAVEL_DSN=

#==========================================================================
# 多租户与平台配置
#==========================================================================

# 系统后台域名（super_admin 访问入口）
ADMIN_DOMAIN=admin.example.com

# 全局 ID 生成器范围（16 位整数，JS 安全）
ID_GENERATOR_MIN=1000000000000000
ID_GENERATOR_MAX=9007199254740991

# 平台默认租户 ID（系统级数据归属）
PLATFORM_TENANT_ID=9007199254740991
# 新租户欢迎赠送积分
PLATFORM_WELCOME_CREDITS=500

# 访客用户 ID 与配额（未登录访问的限流）
GUEST_USER_ID=1
GUEST_INVOKE_MAX_REQUESTS=10
GUEST_CONVERSATION_MAX_REQUESTS=0
GUEST_RATE_LIMIT_PER_IP=30
GUEST_MAX_SESSION_PER_IP=5

# 文件存储默认磁盘（local / s3 / oss）
FILE_STORAGE_DISK=local

# 积分预警阈值（低于此值触发提醒）
CREDIT_WARNING_THRESHOLD=100

#==========================================================================
# 数据隔离配置
#==========================================================================

# 默认隔离策略：shared（共享数据库+行级隔离）/ database（独立数据库）/ schema（独立 Schema，仅 PostgreSQL）
TENANCY_ISOLATION_DEFAULT=shared
# 租户动态连接名前缀（连接名 = 前缀 + tenant_id）
TENANCY_ISOLATION_CONNECTION_PREFIX=tenant.
# 基础连接名（租户连接继承该配置，仅覆盖 database/search_path）
TENANCY_ISOLATION_BASE_CONNECTION=mysql
# 管理员连接名（CREATE/DROP DATABASE 需要，留空则用基础连接）
TENANCY_ISOLATION_ADMIN_CONNECTION=
# setupDatabase 后是否自动运行迁移
TENANCY_ISOLATION_RUN_MIGRATIONS=true
# 迁移文件路径（database 策略在新库上执行的迁移目录）
TENANCY_ISOLATION_MIGRATIONS_PATH=database/migrations
# 独立数据库名模板（{:id} 替换为租户 ID）
TENANCY_ISOLATION_DB_NAME_TEMPLATE=tenant_{:id}
# 独立 Schema 名模板（{:id} 替换为租户 ID，仅 PostgreSQL）
TENANCY_ISOLATION_SCHEMA_NAME_TEMPLATE=tenant_{:id}

#==========================================================================
# 租户加密配置
#==========================================================================

# 系统主密钥（用于加密租户级密钥，生产必须设置 32 位字符串）
APP_MASTER_KEY=
# 加密算法
TENANT_KEY_CIPHER=aes-256-cbc
# 密钥轮换异步队列名（留空则同步执行 re-encrypt）
TENANT_KEY_ROTATION_QUEUE=

#==========================================================================
# 白标品牌配置
#==========================================================================

# Logo 最大尺寸（字节，默认 2MB）
BRANDING_LOGO_MAX_SIZE=2097152
# 默认主色调
BRANDING_DEFAULT_PRIMARY_COLOR=#2563eb
# 默认辅助色
BRANDING_DEFAULT_SECONDARY_COLOR=#64748b
# 默认登录页样式（default / minimal / corporate）
BRANDING_DEFAULT_LOGIN_STYLE=default
# 默认邮件模板
BRANDING_DEFAULT_EMAIL_TEMPLATE=default
# 是否启用自定义域名
BRANDING_CUSTOM_DOMAIN_ENABLED=true

#==========================================================================
# 数据驻留配置
#==========================================================================

# 默认区域（新建租户未指定时使用）
RESIDENCY_DEFAULT_REGION=CN
# 是否启用合规校验（启用后强制拒绝跨区域读写）
RESIDENCY_COMPLIANCE_ENFORCED=true
# 各区域存储磁盘
RESIDENCY_CN_DISK=local
RESIDENCY_US_DISK=local
RESIDENCY_EU_DISK=local
RESIDENCY_APAC_DISK=local
# 是否启用跨区域迁移工具
RESIDENCY_CROSS_REGION_MIGRATION=true

#==========================================================================
# GDPR 合规与数据保留
#==========================================================================

# 当前条款版本
GDPR_TERMS_VERSION=1.0
# 数据擦除匿名化邮箱后缀
GDPR_ERASURE_EMAIL_DOMAIN=deleted.local
# 清理前通知天数
GDPR_CLEANUP_NOTICE_DAYS=7

# 数据保留默认天数
RETENTION_DEFAULT_DAYS=365
# 是否自动清理过期数据
RETENTION_AUTO_CLEANUP=true
# 清理策略：delete（删除）/ anonymize（匿名化）
RETENTION_CLEANUP_STRATEGY=anonymize

#==========================================================================
# AI 网关配置
#==========================================================================

# 默认提供商与模型
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-4o-mini
AI_API_VERSION=v1
AI_STREAMING_ENABLED=true

# 全局超时与重试
AI_TIMEOUT=30
AI_RETRY_ATTEMPTS=2
AI_RETRY_DELAY_MS=500

# 速率限制
AI_RATE_LIMIT_ENABLED=false
AI_RATE_LIMIT_RPM=60

# ---------- 提供商密钥 ----------
# SaaS 网关层密钥（AiGatewayService 使用）
AI_OPENAI_API_KEY=
AI_OPENAI_BASE_URL=https://api.openai.com/v1
AI_OPENAI_TIMEOUT=30

# laravel/ai SDK 密钥（与上面 SaaS 网关层共享 OPENAI_API_KEY）
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
COHERE_API_KEY=
JINA_API_KEY=
VOYAGEAI_API_KEY=
XAI_API_KEY=
ELEVENLABS_API_KEY=

AI_ZHIPU_API_KEY=
AI_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_ZHIPU_TIMEOUT=30

AI_ANTHROPIC_API_KEY=
AI_ANTHROPIC_BASE_URL=https://api.anthropic.com
AI_ANTHROPIC_TIMEOUT=30

AI_DEEPSEEK_API_KEY=
AI_DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_DEEPSEEK_TIMEOUT=30

AI_STABILITY_API_KEY=
AI_STABILITY_BASE_URL=https://api.stability.ai/v2beta
AI_STABILITY_TIMEOUT=60

AI_RUNWAY_API_KEY=
AI_RUNWAY_BASE_URL=https://api.dev.runwayml.com/v1
AI_RUNWAY_TIMEOUT=60

AI_KUAISHOU_API_KEY=
AI_KUAISHOU_BASE_URL=https://api.kuaishou.com/v1
AI_KUAISHOU_TIMEOUT=60

AI_KLING_API_KEY=
AI_KLING_BASE_URL=https://api.klingai.com/v1
AI_KLING_TIMEOUT=60

# ---------- 文本 AI ----------
AI_TEXT_CHAT_MODEL=gpt-4o-mini
AI_TEXT_COMPLETION_MODEL=gpt-4o-mini
AI_TEXT_EMBEDDING_MODEL=text-embedding-3-small
AI_TEXT_JSON_MODE=true
AI_TEXT_TEMPERATURE=0.7
AI_TEXT_MAX_TOKENS=2048
AI_TEXT_MAX_INPUT_LENGTH=16000

# ---------- 图像 AI ----------
AI_IMAGE_DEFAULT_PROVIDER=dalle
AI_IMAGE_DEFAULT_MODEL=dall-e-3
AI_IMAGE_DEFAULT_SIZE=1024x1024
AI_IMAGE_DEFAULT_QUALITY=standard
AI_IMAGE_DEFAULT_STYLE=vivid
AI_IMAGE_DEFAULT_N=1
AI_IMAGE_DEFAULT_STEPS=30
AI_IMAGE_DEFAULT_CFG_SCALE=7.0
AI_IMAGE_MAX_PROMPT_LENGTH=4000
AI_IMAGE_STORAGE_CATEGORY=ai_generated
AI_IMAGE_STORAGE_DISK=
AI_IMAGE_STORAGE_PUBLIC=false

# ---------- 视频 AI ----------
AI_VIDEO_DEFAULT_PROVIDER=runway
AI_VIDEO_DEFAULT_MODEL=gen-3
AI_VIDEO_DEFAULT_RESOLUTION=1280x768
AI_VIDEO_DEFAULT_DURATION=5
AI_VIDEO_DEFAULT_FPS=24
AI_VIDEO_MAX_PROMPT_LENGTH=4000
AI_VIDEO_POLL_INTERVAL=10
AI_VIDEO_MAX_POLL_ATTEMPTS=120
AI_VIDEO_POLL_QUEUE=default
AI_VIDEO_STORAGE_CATEGORY=ai_generated
AI_VIDEO_STORAGE_DISK=
AI_VIDEO_STORAGE_PUBLIC=false
AI_VIDEO_CALLBACK_EVENT=ai.video.task.updated

# ---------- 租户级 AI 默认配置 ----------
AI_TENANT_TEXT_ENABLED=true
AI_TENANT_IMAGE_ENABLED=true
AI_TENANT_VIDEO_ENABLED=true
AI_TENANT_MONTHLY_BUDGET=0
AI_TENANT_OVERAGE_ACTION=block

# ---------- AI 用量与配额 ----------
AI_QUOTA_PERIOD=monthly
AI_QUOTA_WARN_THRESHOLD=0.8
AI_USAGE_RECORDS_ENABLED=true

#==========================================================================
# MFA 多因素认证
#==========================================================================

# 是否全局启用 MFA
MFA_ENABLED=true
# TOTP 应用中显示的发行方名称
MFA_TOTP_ISSUER=Multi-Tenant SaaS
# 验证码有效期（秒）
MFA_CODE_TTL=300
# 最大验证尝试次数（超过后锁定）
MFA_MAX_ATTEMPTS=5
# 信任设备有效天数
TRUSTED_DEVICE_DAYS=30

# IP 白名单（MFA / 访问控制）
IP_WHITELIST_ENABLED=true
IP_WHITELIST_DEFAULT_SCOPE=all

#==========================================================================
# SSO / SAML 单点登录
#==========================================================================

# SP 默认 EntityID（可被租户级配置覆盖）
SAML_SP_ENTITY_ID=saml:sp
# 默认 ACS 断言消费路径（相对站点根）
SAML_ACS_PATH=/api/v1/sso/saml/acs
# 是否强制 IdP 签名校验（生产建议 true）
SAML_REQUIRE_SIGNED=true

#==========================================================================
# Webhook 系统
#==========================================================================

# 最大重试次数（指数退避：10s, 30s, 60s, 120s, 300s）
WEBHOOK_MAX_RETRIES=5
# HTTP 请求超时（秒）
WEBHOOK_TIMEOUT=30
# 签名头部名称
WEBHOOK_SIGNATURE_HEADER=X-Webhook-Signature
# 投递队列名称
WEBHOOK_QUEUE=default

#==========================================================================
# 事件总线
#==========================================================================

# 异步分发队列名称
EVENT_BUS_QUEUE=default
# 事件分发最大重试次数（指数退避：5s, 15s, 30s）
EVENT_BUS_MAX_RETRIES=3
# 外部订阅 Webhook 投递超时（秒）
EVENT_BUS_TIMEOUT=30

#==========================================================================
# 功能开关
#==========================================================================

# 缓存 TTL（秒）
FEATURE_FLAG_CACHE_TTL=300
# 是否在服务启动时自动播种预置开关
FEATURE_FLAG_AUTO_SEED=false

#==========================================================================
# 成本追踪
#==========================================================================

# 默认币种
COST_DEFAULT_CURRENCY=CNY
# 趋势预测月数
COST_FORECAST_MONTHS=3
# 历史数据回溯月数（用于趋势预测）
COST_HISTORY_MONTHS=6

#==========================================================================
# 资源监控（指标监控）
#==========================================================================

# 数据库连接数告警阈值
RESOURCE_DB_CONN_THRESHOLD=100
# 队列积压告警阈值（任务数）
RESOURCE_QUEUE_THRESHOLD=1000
# 缓存命中率告警阈值（百分比）
CACHE_HIT_RATE_THRESHOLD=80.0
# 存储用量告警阈值（MB）
STORAGE_USAGE_THRESHOLD_MB=10240

#==========================================================================
# 通知中心
#==========================================================================

# 是否启用每日通知聚合（digest）
NOTIFICATION_DIGEST_ENABLED=false
# 每日聚合发送时刻（H:i）
NOTIFICATION_DIGEST_SEND_TIME=08:00
# 通知记录保留天数
NOTIFICATION_RETENTION_DAYS=90

#==========================================================================
# 错误追踪与报表
#==========================================================================

# Sentry 集成
SENTRY_ENABLED=false
SENTRY_SAMPLE_RATE=1.0
SENTRY_ENVIRONMENT=production

# 错误聚合时间窗口（小时）
ERROR_AGGREGATION_WINDOW_HOURS=24
# 错误趋势粒度（day / hour）
ERROR_TREND_GRANULARITY=day
# 单次聚合最大错误类型数
ERROR_MAX_GROUPS=100

# 自定义报表
REPORT_DEFAULT_FORMAT=csv
REPORT_PDF_VIEW=pdf.report
REPORT_QUEUE=default
REPORT_DAILY_SEND_TIME=08:00

#==========================================================================
# SLA 与健康检查
#==========================================================================

# 是否启用 SLA 监控
SLA_ENABLED=true
# 默认 SLA 级别（standard / premium / enterprise）
SLA_DEFAULT_LEVEL=standard

#==========================================================================
# CORS / Sanctum / Swagger
#==========================================================================

# CORS 允许的来源（逗号分隔）
CORS_ALLOWED_ORIGINS=localhost,127.0.0.1

# Sanctum
SANCTUM_STATEFUL_DOMAINS=
SANCTUM_TOKEN_PREFIX=

# Swagger / OpenAPI
L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_VALIDATE_DOCS=false

#==========================================================================
# 队列分级
#==========================================================================

# 三级队列名称（high=支付/订阅，default=通知/审计，low=导出/报表/清理）
QUEUE_HIGH=high
QUEUE_DEFAULT=default
QUEUE_LOW=low

#==========================================================================
# 域名 / SSL 模块
#==========================================================================

# 平台域名
PLATFORM_ADMIN_DOMAIN=admin.example.com
PLATFORM_APP_DOMAIN=app.example.com

# 域名管理
DOMAIN_ICP_CHECK_ENABLED=false
DOMAIN_NGINX_MAP_FILE=/etc/nginx/conf.d/allowed-domains.map
DOMAIN_SSL_CERTS_PATH=/etc/nginx/ssl
DOMAIN_SSL_NGINX_MAP_FILE=/etc/nginx/conf.d/ssl-map.conf

# SSL 证书模块
SSL_CERTS_PATH=/app/ssl-certs
SSL_NGINX_MAP_FILE=/app/ssl-certs/ssl-map.conf

#==========================================================================
# API Token 模块
#==========================================================================

APITOKEN_BASE_URL=https://api.example.com
APITOKEN_ADMIN_KEY=
APITOKEN_ADMIN_USER_ID=1
APITOKEN_HTTP_TIMEOUT=15
APITOKEN_DEFAULT_EXPIRED_TIME=-1
APITOKEN_DEFAULT_GROUP=default
APITOKEN_ENABLED=false

#==========================================================================
# 支付模块（独立网关）
#==========================================================================

PAYMENT_GATEWAY=https://pay.example.com
PAYMENT_SERVICE_ID=
PAYMENT_PASSWORD=
PAYMENT_APP_ID=
PAYMENT_NOTIFY_URL=
PAYMENT_RETURN_URL=
PAYMENT_SHOW_URL=
PAYMENT_ENABLED=false
