{
    "name": "dsplat/multi-tenant-saas",
    "type": "library",
    "description": "Laravel 多租户 SaaS 基础框架 - 开箱即用的项目骨架",
    "keywords": [
        "laravel",
        "multi-tenant",
        "saas",
        "framework"
    ],
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "src/Modules/*"
        }
    ],
    "require": {
        "php": "^8.3",
        "barryvdh/laravel-dompdf": "^3.0",
        "laravel/ai": "^0.8.1",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.3",
        "laravel/socialite": "^5.0",
        "maatwebsite/excel": "^3.1",
        "spatie/laravel-health": "^1.0",
        "yansongda/pay": "^3.7",
        "dsplat/multi-tenant-saas-module-infrastructure": "*",
        "dsplat/multi-tenant-saas-module-plugin": "*",
        "dsplat/multi-tenant-saas-module-event": "*",
        "dsplat/multi-tenant-saas-module-billing": "*",
        "dsplat/multi-tenant-saas-module-logging": "*",
        "dsplat/multi-tenant-saas-module-auth": "*",
        "dsplat/multi-tenant-saas-module-user": "*",
        "dsplat/multi-tenant-saas-module-monitoring": "*",
        "dsplat/multi-tenant-saas-module-platform": "*",
        "dsplat/multi-tenant-saas-module-developer-portal": "*",
        "dsplat/multi-tenant-saas-module-conversation": "*",
        "dsplat/multi-tenant-saas-module-workflow": "*",
        "dsplat/multi-tenant-saas-module-ai": "*",
        "dsplat/multi-tenant-saas-module-domain": "*",
        "dsplat/multi-tenant-saas-module-ssl": "*",
        "dsplat/multi-tenant-saas-module-payment": "*",
        "dsplat/multi-tenant-saas-module-api-token": "*",
        "dsplat/multi-tenant-saas-module-form": "*",
        "dsplat/multi-tenant-saas-module-lottery": "*",
        "dsplat/multi-tenant-saas-module-voting": "*",
        "dsplat/multi-tenant-saas-module-sms": "*",
        "dsplat/multi-tenant-saas-module-coupon": "*"
    },
    "require-dev": {
        "brianium/paratest": "^7.8",
        "darkaonline/l5-swagger": "^8.0",
        "fakerphp/faker": "^1.23",
        "laravel/horizon": "^5.0",
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^10.5|^11.0",
        "sentry/sentry-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "MultiTenantSaas\\": "src/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "src/Helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "MultiTenantSaas\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "test": [
            "@php -d memory_limit=2G artisan test --parallel"
        ],
        "test:sequential": [
            "@php -d memory_limit=2G artisan test"
        ],
        "test:filter": [
            "@php -d memory_limit=2G artisan test --parallel --filter"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "MultiTenantSaas\\TenancyServiceProvider"
            ]
        }
    },
    "archive": {
        "exclude": [
            "/docs",
            "/tests",
            "/.ai",
            "/vendor",
            "/storage",
            "/public",
            "/bootstrap",
            "/.env*",
            "/*.md",
            "/phpunit.xml.dist",
            "/artisan",
            "/compose.json",
            "/requirements.md",
            "/ai-runner",
            "/*.sh",
            "/bin",
            "/src/Modules"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
