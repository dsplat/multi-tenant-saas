{
    "name": "dsplat/multi-tenant-saas",
    "type": "library",
    "description": "Laravel 多租户 SaaS 基础框架 - 开箱即用的项目骨架",
    "keywords": [
        "laravel",
        "multi-tenant",
        "saas",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "barryvdh/laravel-dompdf": "^3.0",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.3",
        "laravel/socialite": "^5.0",
        "maatwebsite/excel": "^3.1",
        "spatie/laravel-health": "^1.0"
    },
    "require-dev": {
        "brianium/paratest": "^7.8",
        "darkaonline/l5-swagger": "^8.0",
        "fakerphp/faker": "^1.23",
        "laravel/ai": "^0.8.1",
        "laravel/horizon": "^5.0",
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^10.5|^11.0",
        "sentry/sentry-laravel": "^4.0",
        "yansongda/pay": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "MultiTenantSaas\\": "src/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "src/Helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "MultiTenantSaas\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "test": [
            "@php -d memory_limit=2G artisan test --parallel"
        ],
        "test:sequential": [
            "@php -d memory_limit=2G artisan test"
        ],
        "test:filter": [
            "@php -d memory_limit=2G artisan test --parallel --filter"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "MultiTenantSaas\\TenancyServiceProvider"
            ]
        }
    },
    "archive": {
        "exclude": [
            "/docs",
            "/tests",
            "/.ai",
            "/vendor",
            "/storage",
            "/public",
            "/bootstrap",
            "/.env*",
            "/*.md",
            "/phpunit.xml.dist",
            "/artisan",
            "/compose.json",
            "/requirements.md",
            "/ai-runner",
            "/*.sh",
            "/bin",
            "/.github",
            "/src/Modules/Ai",
            "/src/Modules/ApiToken",
            "/src/Modules/Auth",
            "/src/Modules/Billing",
            "/src/Modules/Conversation",
            "/src/Modules/Coupon",
            "/src/Modules/DeveloperPortal",
            "/src/Modules/Domain",
            "/src/Modules/Event",
            "/src/Modules/Form",
            "/src/Modules/Infrastructure",
            "/src/Modules/Logging",
            "/src/Modules/Lottery",
            "/src/Modules/Monitoring",
            "/src/Modules/Payment",
            "/src/Modules/Platform",
            "/src/Modules/Plugin",
            "/src/Modules/Sms",
            "/src/Modules/SSL",
            "/src/Modules/User",
            "/src/Modules/Voting",
            "/src/Modules/Workflow"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
