# multi_tenant_saas 框架发布配置
# 复制为 config.env 并填写真实值（config.env 已加入 .gitignore）
# 框架以拆分包形式安装在后台项目的 vendor/dsplat/ 下

# 生产服务器（与后台同一服务器）
SERVER_HOST=social.dsplat.com
SERVER_USER=root
WEB_ROOT=/alidata/www/dsplat.com/social.dsplat.com

# 拆分包所在的 vendor 目录（默认 WEB_ROOT/vendor）
VENDOR_DIR=/alidata/www/dsplat.com/social.dsplat.com/vendor

# PHP / Composer（服务器上的可执行路径，用于 dump-autoload 与 artisan cache）
PHP_BIN=/usr/local/php8/bin/php
COMPOSER_BIN=composer
